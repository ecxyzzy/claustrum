{
  "name": "claustrum",
  "version": "0.3.0",
  "description": "An opinionated library for typed, fluent-style, immutable functional programming in TypeScript",
  "homepage": "https://github.com/ecxyzzy/claustrum#readme",
  "bugs": {
    "url": "https://github.com/ecxyzzy/claustrum/issues"
  },
  "license": "MIT",
  "author": "Eddy Chen <e@eddychen.ca>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecxyzzy/claustrum.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./adt": "./dist/adt.mjs",
    "./adt/Either": "./dist/adt/Either.mjs",
    "./adt/Maybe": "./dist/adt/Maybe.mjs",
    "./adt/Nullable": "./dist/adt/Nullable.mjs",
    "./adt/Try": "./dist/adt/Try.mjs",
    "./adt/Validation": "./dist/adt/Validation.mjs",
    "./collections": "./dist/collections.mjs",
    "./collections/Arr": "./dist/collections/Arr.mjs",
    "./collections/Hashable": "./dist/collections/Hashable.mjs",
    "./collections/HashableObject": "./dist/collections/HashableObject.mjs",
    "./collections/HashMap": "./dist/collections/HashMap.mjs",
    "./collections/LazyList": "./dist/collections/LazyList.mjs",
    "./collections/StrMap": "./dist/collections/StrMap.mjs",
    "./concurrent": "./dist/concurrent.mjs",
    "./concurrent/Awaitable": "./dist/concurrent/Awaitable.mjs",
    "./concurrent/Runnable": "./dist/concurrent/Runnable.mjs",
    "./concurrent/Task": "./dist/concurrent/Task.mjs",
    "./concurrent/TaskEither": "./dist/concurrent/TaskEither.mjs",
    "./concurrent/TaskMaybe": "./dist/concurrent/TaskMaybe.mjs",
    "./concurrent/TaskTry": "./dist/concurrent/TaskTry.mjs",
    "./numeric": "./dist/numeric.mjs",
    "./numeric/RichInt": "./dist/numeric/RichInt.mjs",
    "./numeric/SafeInt": "./dist/numeric/SafeInt.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "bumpp": "^11.1.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  },
  "packageManager": "pnpm@11.3.0"
}
